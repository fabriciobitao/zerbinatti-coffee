# ─────────────────────────────────────────────────────────
# CLIENT-SIDE (NEXT_PUBLIC_*) — embarcadas no bundle JS
# ─────────────────────────────────────────────────────────

# Numero WhatsApp comercial (formato internacional: 55 + DDD + numero, somente digitos)
# Ex: 5511999998888 (Brasil + 11 + numero)
NEXT_PUBLIC_WHATSAPP_NUMBER=5511999998888

# Email de contato comercial
NEXT_PUBLIC_CONTACT_EMAIL=contato@zerbinatticoffee.com

# Shopify Storefront (publico por design — escopo read)
NEXT_PUBLIC_SHOPIFY_STORE_DOMAIN=
NEXT_PUBLIC_SHOPIFY_STOREFRONT_TOKEN=

# Analytics — IDs publicos (so carregam apos consent LGPD)
# GA4 measurement ID (formato G-XXXXXXXXXX). Aceita NEXT_PUBLIC_GA_ID OU NEXT_PUBLIC_GA_MEASUREMENT_ID.
NEXT_PUBLIC_GA_ID=
NEXT_PUBLIC_GA_MEASUREMENT_ID=
# Meta Pixel ID (15-16 digitos)
NEXT_PUBLIC_META_PIXEL_ID=

# Turnstile (Cloudflare CAPTCHA invisivel) — site key publica
NEXT_PUBLIC_TURNSTILE_SITE_KEY=

# Sentry — DSN do browser (publico)
NEXT_PUBLIC_SENTRY_DSN=

# URL canonica do site (ex: https://zerbinatticoffee.com) — usada nos emails e nos schemas
NEXT_PUBLIC_SITE_URL=

# Sanity CMS — Studio embutido em /studio
NEXT_PUBLIC_SANITY_PROJECT_ID=
NEXT_PUBLIC_SANITY_DATASET=production
NEXT_PUBLIC_SANITY_API_VERSION=2025-01-01

# ─────────────────────────────────────────────────────────
# SERVER-ONLY — NUNCA expor com prefixo NEXT_PUBLIC_
# ─────────────────────────────────────────────────────────

# Shopify Admin (escopo minimo) — apenas em route handlers Node
SHOPIFY_ADMIN_API_TOKEN=
# Shopify webhooks — verificacao HMAC-SHA256
SHOPIFY_WEBHOOK_SECRET=

# Resend (transacional + newsletter)
RESEND_API_KEY=
RESEND_AUDIENCE_ID=
RESEND_FROM_EMAIL=Zerbinatti <newsletter@zerbinatticoffee.com>
CONTACT_INBOX=
CONTACT_FROM=
# Email para receber notificacoes B2B (default: CONTACT_INBOX)
CONTACT_NOTIFY_EMAIL=

# Newsletter — segredo HMAC para tokens double opt-in / unsubscribe (32+ chars)
NEWSLETTER_SECRET=

# Token de leitura para preview de drafts no Sanity (opcional)
SANITY_API_READ_TOKEN=

# Upstash Redis (rate limiting via Edge Middleware)
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Turnstile — secret server-side
TURNSTILE_SECRET_KEY=

# Sentry server + upload de source maps no build
SENTRY_DSN=
SENTRY_AUTH_TOKEN=
SENTRY_ORG=
SENTRY_PROJECT=
